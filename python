import pygame
import serial
import math
import time
from collections import deque

SERIAL_PORT = "COM3"      # Cambiar según tu puerto
BAUD_RATE = 9600

MAX_DISTANCE_CM = 200
WINDOW_WIDTH = 1000
WINDOW_HEIGHT = 700

CENTER_X = WINDOW_WIDTH // 2
CENTER_Y = WINDOW_HEIGHT - 80
RADAR_RADIUS = 550

GREEN = (0, 255, 0)
DARK_GREEN = (0, 60, 0)
BLACK = (0, 0, 0)
RED = (255, 70, 70)
YELLOW = (255, 255, 0)
WHITE = (255, 255, 255)


class RadarObject:
    def __init__(self, angle, distance):
        self.angle = angle
        self.distance = distance
        self.last_distance = distance
        self.last_time = time.time()
        self.current_time = time.time()
        self.speed = 0
        self.x = 0
        self.y = 0
        self.future_x = 0
        self.future_y = 0
        self.update_position()

    def update(self, angle, distance):
        self.last_distance = self.distance
        self.last_time = self.current_time

        self.angle = angle
        self.distance = distance
        self.current_time = time.time()

        delta_d = self.distance - self.last_distance
        delta_t = self.current_time - self.last_time

        if delta_t > 0:
            self.speed = delta_d / delta_t

        self.update_position()

    def update_position(self):
        theta = math.radians(self.angle)

        self.x = self.distance * math.cos(theta)
        self.y = self.distance * math.sin(theta)

        future_distance = self.distance + self.speed * 1.0

        if future_distance < 0:
            future_distance = 0

        self.future_x = future_distance * math.cos(theta)
        self.future_y = future_distance * math.sin(theta)


def polar_to_screen(angle, distance):
    theta = math.radians(angle)
    scaled_distance = (distance / MAX_DISTANCE_CM) * RADAR_RADIUS

    x = CENTER_X + scaled_distance * math.cos(theta)
    y = CENTER_Y - scaled_distance * math.sin(theta)

    return int(x), int(y)


def draw_radar_grid(screen, font):
    screen.fill(BLACK)

    for r in range(100, RADAR_RADIUS + 1, 100):
        pygame.draw.arc(
            screen,
            DARK_GREEN,
            (CENTER_X - r, CENTER_Y - r, 2 * r, 2 * r),
            0,
            math.pi,
            1
        )

    for angle in range(0, 181, 30):
        theta = math.radians(angle)
        x = CENTER_X + RADAR_RADIUS * math.cos(theta)
        y = CENTER_Y - RADAR_RADIUS * math.sin(theta)
        pygame.draw.line(screen, DARK_GREEN, (CENTER_X, CENTER_Y), (x, y), 1)

        label = font.render(str(angle) + "°", True, GREEN)
        screen.blit(label, (x - 15, y - 20))

    pygame.draw.line(screen, GREEN, (CENTER_X - RADAR_RADIUS, CENTER_Y), (CENTER_X + RADAR_RADIUS, CENTER_Y), 2)
    pygame.draw.line(screen, GREEN, (CENTER_X, CENTER_Y), (CENTER_X, CENTER_Y - RADAR_RADIUS), 2)

    title = font.render("RADAR 2D - Arduino + Python", True, GREEN)
    screen.blit(title, (30, 20))


def draw_sweep_line(screen, angle):
    theta = math.radians(angle)
    x = CENTER_X + RADAR_RADIUS * math.cos(theta)
    y = CENTER_Y - RADAR_RADIUS * math.sin(theta)
    pygame.draw.line(screen, GREEN, (CENTER_X, CENTER_Y), (x, y), 3)


def draw_object(screen, font, obj):
    if obj.distance < 0 or obj.distance > MAX_DISTANCE_CM:
        return

    x, y = polar_to_screen(obj.angle, obj.distance)

    future_distance = obj.distance + obj.speed * 1.0
    future_x, future_y = polar_to_screen(obj.angle, max(0, future_distance))

    pygame.draw.circle(screen, RED, (x, y), 7)
    pygame.draw.circle(screen, YELLOW, (future_x, future_y), 5)

    pygame.draw.line(screen, YELLOW, (x, y), (future_x, future_y), 1)

    info = f"{obj.distance:.1f} cm | {obj.speed:.1f} cm/s"
    text = font.render(info, True, WHITE)
    screen.blit(text, (x + 10, y - 10))


def read_serial_data(ser):
    try:
        line = ser.readline().decode("utf-8").strip()

        if not line:
            return None

        parts = line.split(",")

        if len(parts) != 2:
            return None

        angle = int(parts[0])
        distance = float(parts[1])

        return angle, distance

    except:
        return None


def main():
    pygame.init()

    screen = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
    pygame.display.set_caption("Radar 2D")

    font = pygame.font.SysFont("Arial", 18)
    clock = pygame.time.Clock()

    objects = {}
    trail = deque(maxlen=80)

    try:
        ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=0.05)
        time.sleep(2)
        serial_connected = True
    except:
        ser = None
        serial_connected = False
        print("No se pudo conectar al puerto serial. Revisá SERIAL_PORT.")

    running = True
    current_angle = 0

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        if serial_connected:
            data = read_serial_data(ser)

            if data:
                angle, distance = data
                current_angle = angle

                if distance > 0:
                    key = round(angle / 10) * 10

                    if key not in objects:
                        objects[key] = RadarObject(angle, distance)
                    else:
                        objects[key].update(angle, distance)

                    trail.append((angle, distance, time.time()))

        draw_radar_grid(screen, font)
        draw_sweep_line(screen, current_angle)

        now = time.time()

        for angle, distance, timestamp in trail:
            if now - timestamp < 2:
                x, y = polar_to_screen(angle, distance)
                pygame.draw.circle(screen, GREEN, (x, y), 3)

        for obj in objects.values():
            draw_object(screen, font, obj)

        status = "Serial conectado" if serial_connected else "Serial NO conectado"
        status_text = font.render(status, True, WHITE)
        screen.blit(status_text, (30, 50))

        pygame.display.flip()
        clock.tick(60)

    if ser:
        ser.close()

    pygame.quit()


if __name__ == "__main__":
    main()
